<Window x:Class="Explorer11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Explorer11" Height="720" Width="1100" Background="#F3F3F4"
        WindowStartupLocation="CenterScreen" AllowsTransparency="False">
    <Grid Margin="12">
        <Border Background="#FFFFFF" CornerRadius="12" Padding="8" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Top bar / address -->
                <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" LastChildFill="True" Margin="6">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Spacing="6">
                        <Button Width="36" Height="36" Content="◀" Click="BackButton_Click" Background="#F0F0F0"/>
                        <Button Width="36" Height="36" Content="▶" Click="ForwardButton_Click" Background="#F0F0F0"/>
                    </StackPanel>

                    <Border CornerRadius="8" Background="#F6F6F7" Padding="8,6" VerticalAlignment="Center" Margin="8">
                        <DockPanel>
                            <TextBox Name="AddressBar" KeyDown="AddressBar_KeyDown" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" FontSize="14" />
                        </DockPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Spacing="8">
                        <Button Width="36" Height="36" Content="🔍" Background="#F0F0F0"/>
                        <Button Width="36" Height="36" Content="⋯" Background="#F0F0F0"/>
                    </StackPanel>
                </DockPanel>

                <!-- Sidebar -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="8,12,6,12">
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="Quick access" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                    <ListBox BorderThickness="0" Background="Transparent" SelectedIndex="0">
                        <ListBoxItem Content="🏠  Home" Padding="8"/>
                        <ListBoxItem Content="📄  Documents" Padding="8"/>
                        <ListBoxItem Content="⬇️  Downloads" Padding="8"/>
                        <ListBoxItem Content="🖼️  Pictures" Padding="8"/>
                        <ListBoxItem Content="🗂️  This PC" Padding="8"/>
                    </ListBox>
                </StackPanel>

                <!-- Main content: folder tiles and details -->
                <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="6,12,12,12" Background="Transparent">
                    <StackPanel>
                        <WrapPanel ItemWidth="140" ItemHeight="110" Margin="4" Name="TilePanel">
                            <!-- Example folder tiles; actual items are populated at runtime -->
                            <Border Width="140" Height="110" Background="#FFFFFF" CornerRadius="8" Margin="6" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="📁" FontSize="28"/>
                                    <TextBlock Text="Documents" FontWeight="Bold" Margin="0,6,0,0"/>
                                    <TextBlock Text="This PC\Documents" FontSize="11" Foreground="#666"/>
                                </StackPanel>
                            </Border>
                            <Border Width="140" Height="110" Background="#FFFFFF" CornerRadius="8" Margin="6" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="🖼️" FontSize="28"/>
                                    <TextBlock Text="Pictures" FontWeight="Bold" Margin="0,6,0,0"/>
                                    <TextBlock Text="This PC\Pictures" FontSize="11" Foreground="#666"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Separator Margin="6"/>

                        <ListBox Name="FileListView" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2" Background="#FFFFFF" CornerRadius="6" Padding="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Type}" FontSize="11" Foreground="#777"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Type}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#999" FontSize="12"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Border>
    </Grid>
</Window>