<Window x:Class="Explorer11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Explorer11" Height="700" Width="1000" Background="#F5F5F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    Background="White" VerticalAlignment="Center" Padding="10">
            <Button Name="BackButton" Click="BackButton_Click" Width="40" Height="40" 
                    Background="#E5E5E5" Foreground="Black" Margin="0,0,5,0" FontSize="18">◀</Button>
            <Button Name="ForwardButton" Click="ForwardButton_Click" Width="40" Height="40" 
                    Background="#E5E5E5" Foreground="Black" Margin="0,0,10,0" FontSize="18">▶</Button>
            <Button Name="HomeButton" Click="HomeButton_Click" Width="40" Height="40" 
                    Background="#E5E5E5" Foreground="Black" Margin="0,0,5,0" FontSize="18">🏠</Button>
            <TextBox Name="AddressBar" KeyDown="AddressBar_KeyDown" Padding="10,5" 
                     VerticalAlignment="Center" Foreground="Black" Background="White" Margin="10,0"/>
        </StackPanel>

        <!-- Sidebar -->
        <StackPanel Grid.Row="1" Grid.Column="0" Background="White" Padding="10">
            <Button Click="HomeButton_Click" Content="🏠 Home" Padding="10" Margin="0,5" 
                    Background="#F0F0F0" Foreground="Black" HorizontalAlignment="Stretch"/>
            <Button Click="DocumentsButton_Click" Content="📄 Documents" Padding="10" Margin="0,5" 
                    Background="#F0F0F0" Foreground="Black" HorizontalAlignment="Stretch"/>
            <Button Click="DownloadsButton_Click" Content="⬇️ Downloads" Padding="10" Margin="0,5" 
                    Background="#F0F0F0" Foreground="Black" HorizontalAlignment="Stretch"/>
            <Button Click="PicturesButton_Click" Content="🖼️ Pictures" Padding="10" Margin="0,5" 
                    Background="#F0F0F0" Foreground="Black" HorizontalAlignment="Stretch"/>
        </StackPanel>

        <!-- File List -->
        <ListBox Name="FileListView" Grid.Row="1" Grid.Column="1" Background="#FAFAFA" 
                 MouseDoubleClick="FileListView_MouseDoubleClick" Padding="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10,8" Background="White" Margin="0,2" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="24" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="Black"/>
                                <TextBlock Text="{Binding Type}" FontSize="11" Foreground="#666"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Type}" FontSize="12" 
                                      VerticalAlignment="Center" Foreground="#999" TextAlignment="Right"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>